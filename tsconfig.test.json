    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "isolatedModules": false,
        "types": ["node", "jest"]
    },
    "include": ["src/main/**/*", "src/common/**/*", "src/renderer/utils/**/*", "tests/**/*"]
}
